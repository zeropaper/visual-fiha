{
  "private": true,
  "name": "visual-fiha-web",
  "version": "4.0.0-dev.0",
  "preview": true,
  "description": "VJing extension for VS Code",
  "author": "Valentin Vago <zeropaper@irata.ch> (https://zeropaper.style/)",
  "license": "MIT",
  "engines": {
    "node": "v22.16.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run --reporter=verbose",
    "test:watch": "vitest --reporter=verbose --watch",
    "test:coverage": "vitest run --reporter=verbose --coverage",
    "copy-typescript": "cp node_modules/typescript/lib/typescript.js public/typescript.js",
    "gen-editor-types:scriptable": "tsc ./src/utils/Scriptable.editor.types.ts --lib dom,esnext -d --emitDeclarationOnly --ignoreConfig",
    "gen-editor-types:canvas": "tsc ./src/layers/Canvas2D/canvasTools.ts --lib dom,esnext -d --emitDeclarationOnly --ignoreConfig",
    "gen-editor-types:threejs": "pnpm run gen-editor-types:threejs:module && pnpm run gen-editor-types:threejs:utils",
    "gen-editor-types:threejs:module": "rm -rf ./three-copy && cp -rfH ./node_modules/@types/three ./three-copy && dtsroll ./three-copy/index.d.ts && mv ./three-copy/index.d.ts ./src/layers/ThreeJS/three-bundle.d.ts && rm -rf ./three-copy",
    "gen-editor-types:threejs:utils": "tsc ./src/layers/ThreeJS/threeTools.ts --lib dom,esnext -d --emitDeclarationOnly --ignoreConfig",
    "gen-editor-types:misc": "tsc ./src/utils/miscTools.ts --lib dom,esnext -d --emitDeclarationOnly --ignoreConfig",
    "gen-editor-types:math": "tsc ./src/utils/mathTools.ts --lib dom,esnext -d --emitDeclarationOnly --ignoreConfig",
    "gen-editor-types": "pnpm gen-editor-types:scriptable && pnpm gen-editor-types:canvas && pnpm gen-editor-types:threejs && pnpm gen-editor-types:misc && pnpm gen-editor-types:math",
    "postgen-editor-types": "find ./src -name '*.d.ts' -exec bash -c 'mv \"$0\" \"${0%.d.ts}.editor-types.txt\"' {} \\;",
    "prepare": "husky && pnpm run copy-typescript && pnpm run gen-editor-types",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "devDependencies": {
    "@biomejs/biome": "catalog:",
    "@chromatic-com/storybook": "catalog:",
    "@commitlint/cli": "catalog:",
    "@commitlint/config-conventional": "catalog:",
    "@storybook/addon-a11y": "catalog:",
    "@storybook/addon-docs": "catalog:",
    "@storybook/addon-onboarding": "catalog:",
    "@storybook/addon-vitest": "catalog:",
    "@storybook/react": "catalog:",
    "@storybook/react-vite": "catalog:",
    "@types/lodash": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@types/react-syntax-highlighter": "catalog:",
    "@types/three": "catalog:",
    "@vitejs/plugin-react": "catalog:",
    "@vitest/browser": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "canvas": "catalog:",
    "dtsroll": "catalog:",
    "happy-dom": "catalog:",
    "husky": "catalog:",
    "jsdom": "catalog:",
    "lint-staged": "catalog:",
    "playwright": "catalog:",
    "storybook": "catalog:",
    "typescript": "catalog:",
    "typescript-plugin-css-modules": "catalog:",
    "vite": "catalog:",
    "vite-plugin-monaco-editor": "catalog:",
    "vite-plugin-pwa": "catalog:",
    "vite-plugin-vercel": "catalog:",
    "vitest": "catalog:"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/zeropaper/visual-fiha.git"
  },
  "bugs": {
    "url": "https://github.com/zeropaper/visual-fiha/issues"
  },
  "homepage": "https://github.com/zeropaper/visual-fiha",
  "dependencies": {
    "@revealjs/react": "catalog:",
    "@tailwindcss/vite": "catalog:",
    "intro.js": "catalog:",
    "lodash": "catalog:",
    "lucide-react": "catalog:",
    "monaco-editor": "catalog:",
    "openai": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "react-markdown": "catalog:",
    "react-syntax-highlighter": "catalog:",
    "rehype-raw": "catalog:",
    "reveal.js": "catalog:",
    "sonner": "catalog:",
    "tailwindcss": "catalog:",
    "three": "catalog:",
    "use-stick-to-bottom": "catalog:",
    "zod": "catalog:"
  },
  "lint-staged": {
    "*.{js,ts,cjs,mjs,d.cts,d.mts,jsx,tsx,json,jsonc}": [
      "biome check --files-ignore-unknown=true --diagnostic-level=error --write --no-errors-on-unmatched"
    ]
  },
  "packageManager": "pnpm@10.17.1",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "@biomejs/biome",
      "@parcel/watcher",
      "canvas"
    ]
  }
}
